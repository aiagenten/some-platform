NEXT_PUBLIC_SUPABASE_URL=https://dlbkcopcfashhuowrybb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Drive OAuth (E14)
GOOGLE_DRIVE_CLIENT_ID=your-google-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-client-secret

# OneDrive / Microsoft OAuth (E14)
ONEDRIVE_CLIENT_ID=your-microsoft-client-id
ONEDRIVE_CLIENT_SECRET=your-microsoft-client-secret
ONEDRIVE_TENANT=common

# AI Agents (Video Studio) — /api/ai and /api/video/ai-director
# Primary: OpenRouter (supports many models incl. Claude)
OPENROUTER_API_KEY=your-openrouter-key-here
# Fallback: OpenAI direct
OPENAI_API_KEY=your-openai-key-here

# Anthropic Claude API — Article AI generation (/api/articles/generate, /api/articles/suggestions)
# If set, uses direct Anthropic API; otherwise falls back to OpenRouter
ANTHROPIC_API_KEY=your-anthropic-key-here
